From 4c1f7f5e8c9d2a1b3e6f8a9c7d4e2b1a0f8c6d5e Mon Sep 17 00:00:00 2001
From: Build System <build@yocto.local>
Date: Mon, 13 Jan 2025 02:00:00 +0000
Subject: [PATCH] Makefile fixups for OE builds

Adapt Makefile.public for Yocto/OpenEmbedded cross-compilation.

Upstream-Status: Inappropriate [embedded specific]
---
 Makefile.public | 32 ++++++++++----------------------
 1 file changed, 10 insertions(+), 22 deletions(-)

diff --git a/Makefile.public b/Makefile.public
index c44d95e..b8c02ec 100644
--- a/Makefile.public
+++ b/Makefile.public
@@ -19,10 +19,10 @@
 # LIABILITY, WHETHER IN AN ACTION OF CONTRACT, TORT OR OTHERWISE, ARISING
 # FROM, OUT OF OR IN CONNECTION WITH THE SOFTWARE OR THE USE OR OTHER
 # DEALINGS IN THE SOFTWARE.
-################################################################################
+################################################################################

-CXX:= gcc
 SRCS:= gst-nvcustomevent.c
+libdir ?= /usr/lib

 INCS:= $(wildcard *.h)
 OUT_DIR ?= .
@@ -30,38 +30,26 @@ SO_NAME := libgstnvcustomhelper.so
 LIB:= $(OUT_DIR)/$(SO_NAME)
 OBJS :=  $(SRCS:%.c=$(OUT_DIR)/%.o)

-TARGET_DEVICE = $(shell gcc -dumpmachine | cut -f1 -d -)
-ifeq ($(TARGET_DEVICE),aarch64)
-  LIB_INSTALL_DIR?=/usr/lib/aarch64-linux-gnu/tegra/
-  CFLAGS:=
-else
-  NVDS_VERSION ?=8.0
-  LIB_INSTALL_DIR ?=/opt/nvidia/deepstream/deepstream-$(NVDS_VERSION)/lib/
-  CFLAGS:= -DDS_VERSION=\"8.0.0\"
-endif
-
 CFLAGS+= -fPIC

 LIBS := -shared -Wl,-no-undefined

-LIBS+= -L$(LIB_INSTALL_DIR) -ldl\
-        -Wl,-rpath,$(LIB_INSTALL_DIR)
-
-PKGS:= gstreamer-1.0 gstreamer-base-1.0 gstreamer-video-1.0
+PKGS:= gstreamer-1.0
 CFLAGS+= $(shell pkg-config --cflags $(PKGS))
 LIBS+= $(shell pkg-config --libs $(PKGS))

 all: $(LIB)

 $(OUT_DIR)/%.o: %.c $(INCS) Makefile
-	@echo $(CFLAGS)
-	$(CXX) -c -o $@ $(CFLAGS) $<
+	$(CC) -c -o $@ $(CFLAGS) $<

 $(LIB): $(OBJS) Makefile
-	$(CXX) -o $@ $(OBJS) $(LIBS)
+	$(CC) -o $@ $(LDFLAGS) $(OBJS) $(LIBS)

 install: $(LIB)
-	cp -rv $(LIB) $(LIB_INSTALL_DIR)
+	install -d $(DESTDIR)$(libdir)
+	install -m0644 $(LIB) $(DESTDIR)$(libdir)/$(SO_NAME).1.0.0
+	ln -sf $(SO_NAME).1.0.0 $(DESTDIR)$(libdir)/$(SO_NAME)

 clean:
 	rm -rf $(OBJS) $(LIB)
--
2.39.2

