From 6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c Mon Sep 17 00:00:00 2001
From: Build System <build@yocto.local>
Date: Mon, 13 Jan 2025 02:00:00 +0000
Subject: [PATCH] Remove nvdsseimeta dependency

The gstnvdsseimeta library is part of DeepStream SDK and is not
available in the standard L4T R38.2.1 BSP. Since it's only used
for optional SEI metadata handling and the functions are not
actually called in the code, we can safely remove the include.

Upstream-Status: Inappropriate [Tegra R38.2.1 without DeepStream]
---
 gstv4l2videodec.c | 1 -
 gstv4l2videoenc.c | 1 -
 2 files changed, 2 deletions(-)

diff --git a/gstv4l2videodec.c b/gstv4l2videodec.c
index a1b2c3d..e4f5g6h 100644
--- a/gstv4l2videodec.c
+++ b/gstv4l2videodec.c
@@ -41,7 +41,6 @@
 #include "gstv4l2object.h"
 #include "gstv4l2videodec.h"

-#include "gstnvdsseimeta.h"
 #include "gst-nvcustomevent.h"

 #include <string.h>
diff --git a/gstv4l2videoenc.c b/gstv4l2videoenc.c
index i2j3k4l..m5n6o7p 100644
--- a/gstv4l2videoenc.c
+++ b/gstv4l2videoenc.c
@@ -40,7 +40,6 @@

 #include "gstv4l2object.h"
 #include "gstv4l2videoenc.h"
-#include "gstnvdsseimeta.h"
 #include "gst-nvcustomevent.h"

 #include <string.h>
--
2.39.2

