<?xml version="1.0"?>
<!-- NVIDIA Jetson AGX Thor flash configuration -->
<partition_layout version="01.00.0000">
    <device type="sdmmc" instance="0">
        <partition name="BCT" type="boot_config_table">
            <allocation_policy>sequential</allocation_policy>
            <filesystem_type>basic</filesystem_type>
            <size>262144</size>
            <file_system_attribute>0</file_system_attribute>
        </partition>
        
        <!-- EFI System Partition for SBSA/UEFI boot -->
        <partition name="esp" type="data">
            <allocation_policy>sequential</allocation_policy>
            <filesystem_type>basic</filesystem_type>
            <size>67108864</size>
            <file_system_attribute>0</file_system_attribute>
            <filename>esp.img</filename>
        </partition>
        
        <partition name="APP" type="data">
            <allocation_policy>sequential</allocation_policy>
            <filesystem_type>basic</filesystem_type>
            <size>APPSIZE</size>
            <file_system_attribute>0x8</file_system_attribute>
            <filename>APPFILE</filename>
        </partition>
    </device>
</partition_layout>
